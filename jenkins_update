pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/IreneAisha10/dockp.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat "docker build -t ireneaisha10/myapp ."
            }
        }

      stage('Push to Docker Hub') {
    steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-creds',
        usernameVariable: 'USER',
        passwordVariable: 'PASS')]) {

            bat "docker login -u %USER% -p %PASS%"
            bat "docker push ireneaisha10/myapp:latest"
        }
    }
}

        stage('Run Container') {
            steps {
                bat "docker run ireneaisha10/myapp"
            }
        }
    }
}
